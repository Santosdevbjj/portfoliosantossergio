{
  "semi": true,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "singleAttributePerLine": true,
  "embeddedLanguageFormatting": "auto",
  "proseWrap": "preserve",
  "htmlWhitespaceSensitivity": "css",

  "plugins": [
    "@trivago/prettier-plugin-sort-imports",
    "prettier-plugin-tailwindcss"
  ],

  "// Import Sorting": "Prioriza React 19, Next 16.2 e Dicionários Multilíngues",
  "importOrder": [
    "^(react/(.*)$)|^(react$)",
    "^(next/(.*)$)|^(next$)",
    "<THIRD_PARTY_MODULES>",
    "",
    "^@/dictionaries/(.*)$",
    "^@/types/(.*)$",
    "^@/config/(.*)$",
    "^@/lib/(.*)$",
    "^@/hooks/(.*)$",
    "^@/components/(.*)$",
    "^@/styles/(.*)$",
    "^[./]"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,

  "// Tailwind Config": "Otimizado para Tailwind v4.2 e funções de junção de classes",
  "tailwindAttributes": ["className", "class", "tw"],
  "tailwindFunctions": ["clsx", "twMerge", "twJoin", "cn", "cva"],
  "tailwindConfig": "./tailwind.config.ts",

  "overrides": [
    {
      "files": ["src/app/api/**/*", "src/app/**/og.*"],
      "options": {
        "printWidth": 120,
        "bracketSameLine": true,
        "singleAttributePerLine": false
      }
    },
    {
      "files": ["*.json", "*.jsonc", ".prettierrc"],
      "options": {
        "parser": "json",
        "singleQuote": false
      }
    },
    {
      "// Proteção de Assets": "Garante que o linter não toque em referências binárias",
      "files": ["public/**/*", "**/*.pdf", "**/*.png"],
      "options": {
        "requirePragma": true
      }
    }
  ]
}
