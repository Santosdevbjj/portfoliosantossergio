{
  "compilerOptions": {
    /* --- MOTOR NATIVO TS 6.0 (BRIDGE TO TS 7.0) --- */
    "target": "ES2025", 
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "ESNext",
    /* 'Bundler' é o padrão ouro para Next.js 16 e Turbopack */
    "moduleResolution": "Bundler", 
    "moduleDetection": "force",
    
    /* --- COMPLIANCE TS 6.0 & ESTRUTURA --- */
    "rootDir": "./src",
    /* Removido baseUrl para evitar depreciação; usamos paths relativos ao rootDir */
    "noEmit": true,
    "verbatimModuleSyntax": true,
    
    /* --- RIGOR DE MISSÃO CRÍTICA (NÍVEL SENIOR) --- */
    "strict": true,
    "noUncheckedIndexedAccess": true, 
    "exactOptionalPropertyTypes": true, 
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false, 

    /* --- NEXT.JS 16 & REACT 19 ARCHITECTURE --- */
    "jsx": "react-jsx",
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.tsbuildinfo",
    
    /* --- INTEROP & SECURITY --- */
    "esModuleInterop": true,         
    "resolveJsonModule": true,
    "allowJs": true, 
    "skipLibCheck": true, /* Evita que erros em libs de terceiros parem o deploy */
    "forceConsistentCasingInFileNames": true,

    /* --- PERFORMANCE & TYPES (TS 6.0 Default fix) --- */
    /* Explicitamos 'node' para evitar o erro 'Cannot find name process' */
    "types": ["node"],

    /* --- INFRASTRUCTURE PATHS (Future-Proofing) --- */
    /* Alinhado com a nova regra de remover o baseUrl */
    "paths": {
      "@/*": ["./src/*"],
      "#/*": ["./src/*"]
    },

    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/**/*",
    "next.config.mjs"
  ],

  "exclude": [
    "node_modules", 
    ".next", 
    "out",
    "dist",
    "build"
  ]
}
