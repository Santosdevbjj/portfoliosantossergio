{
  "compilerOptions": {
    /* --- MOTOR NATIVO TS 6.x (PREPARADO PARA NEXT.JS 16.2) --- */
    "target": "ES2025",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",

    /* --- COMPLIANCE VERCEL & TURBOPACK --- */
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "incremental": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    /* --- RIGOR DE NÍVEL SENIOR (PROTEÇÃO DE DADOS) --- */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    /* Proteção extra para os novos Async APIs do Next.js 16 */
    "noPropertyAccessFromIndexSignature": true,

    /* --- INTEROP & SECURITY --- */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    /* --- PERFORMANCE & CACHE --- */
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.tsbuildinfo",
    "types": ["node"],

    /* --- INFRASTRUCTURE PATHS (TS 6.0 COMPLIANCE) --- */
    "paths": {
      "@/*": ["./src/*"],
      "#/*": ["./src/*"]
    },

    "plugins": [
      {
        "name": "next"
      }
    ]
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    /* Tipagens geradas pelo Next.js 16.2 (Build & Dev) */
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "src/**/*",
    /* Inclui os arquivos de configuração para checagem de tipos */
    "next.config.ts",
    "AGENTS.md"
  ],

  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "build"
  ]
}
