{
  "compilerOptions": {
    /* --- MOTOR NATIVO TS 6.0 (BRIDGE TO TS 7.0) --- */
    "target": "ES2025",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "ESNext",
    /* 'Bundler' é o padrão para Next.js 16 (Turbopack/Webpack) */
    "moduleResolution": "Bundler",
    "moduleDetection": "force",

    /* --- AJUSTE DE ESTRUTURA PARA DEPLOY (SOLUÇÃO DO ERRO) --- */
    /* Removido "rootDir": "./src" para permitir arquivos de configuração na raiz */
    "baseUrl": ".",
    "noEmit": true,
    "verbatimModuleSyntax": true,

    /* --- RIGOR DE MISSÃO CRÍTICA (NÍVEL SENIOR) --- */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,

    /* --- NEXT.JS 16 & REACT 19 ARCHITECTURE --- */
    "jsx": "react-jsx",
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.tsbuildinfo",

    /* --- INTEROP & SECURITY --- */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* --- PERFORMANCE & TYPES (TS 6.0 FIX) --- */
    "types": ["node"],

    /* --- INFRASTRUCTURE PATHS (TS 6.0 COMPLIANCE) --- */
    "paths": {
      "@/*": ["./src/*"],
      "#/*": ["./src/*"]
    },

    "plugins": [
      {
        "name": "next"
      }
    ]
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "src/**/*",
    "next.config.mjs"
  ],

  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "build"
  ]
}
