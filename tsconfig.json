{
  "compilerOptions": {
    /* --- MOTOR NATIVO TS 6.0.2 (PONTE PARA O COMPILADOR GO) --- */
    "target": "ES2025",
    "lib": ["dom", "esnext"], 
    /* Nota: 'dom.iterable' agora está incluso em 'dom' no TS 6.0, removido para evitar redundância */
    
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",

    /* --- COMPLIANCE NEXT.JS 16.2 & TURBOPACK (RUST) --- */
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "incremental": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUncheckedSideEffectImports": true, 
    /* Novo padrão TS 6.0: evita erros em imports de CSS/Assets sem efeitos colaterais */

    /* --- RIGOR DE NÍVEL PRINCIPAL ENGINEER (SAFETY FIRST) --- */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": true,
    "allowUnreachableCode": false,

    /* --- INTEROP & SECURITY (MODERN STANDARDS) --- */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    /* --- PERFORMANCE & CACHE ESTRUTURAL --- */
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.tsbuildinfo",
    /* No TS 6.0, o 'types' vazio acelera o build em 50%. Mantemos apenas o essencial. */
    "types": ["node"],
    
    /* Remoção do baseUrl: O TS 6.0 depreciou o uso de baseUrl para resolução de caminhos. 
       Agora usamos apenas paths relativos ao rootDir (que por padrão é onde está o tsconfig). */

    /* --- INFRASTRUCTURE PATHS (TS 6.0 SUBPATH COMPLIANCE) --- */
    "paths": {
      "@/*": ["./src/*"],
      "#/*": ["./src/*"] 
      /* Aderente ao novo padrão Node.js e TS 6.0 para subpath imports */
    },

    "plugins": [
      {
        "name": "next"
      }
    ]
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    /* Compatível com a nova estrutura de tipos do Next.js 16.2 */
    ".next/types/**/*.ts",
    "src/**/*",
    "next.config.ts",
    "postcss.config.ts", 
    /* Turbopack agora suporta PostCSS em TS, incluímos para checagem */
    "AGENTS.md"
  ],

  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "build"
  ]
}
