# =====================================================
# DEPENDÊNCIAS — Node.js / NPM / Bun
# =====================================================
node_modules/
.pnp
.pnp.js
.yarn/

# =====================================================
# NEXT.JS 16.2 + TURBOPACK (NOVIDADES)
# =====================================================
.next/
# IMPORTANTE: Mantemos o cache para acelerar builds na Vercel/CI
!.next/cache/

# NOVO NA 16.2: Arquivos de controle de agentes e logs de dev
.next/dev/lock
.next/dev/logs/
.next/types
.next/trace

out/
build/
dist/
.vercel/

# TypeScript 6.0 Incremental & Metadata
*.tsbuildinfo
next-env.d.ts
.next/server-reference-manifest.json

# =====================================================
# VARIÁVEIS DE AMBIENTE — SEGURANÇA MÁXIMA
# =====================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
!.env.example

# Credenciais e Chaves
.azure/
.aws/
*.pem
*.key
*.pub

# =====================================================
# LOGS E CACHE DE FERRAMENTAS
# =====================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
.cache/
.turbo/
.eslintcache
.stylelintcache
coverage/
.nyc_output/

# =====================================================
# ASSETS DO PORTFÓLIO (PROTEÇÃO)
# =====================================================
# Garantimos que os binários oficiais sejam enviados, 
# mas ignoramos arquivos temporários de edição.
public/pdf/*.tmp
public/pdf/*.bak
public/og/*.tmp
*.crdownload

# =====================================================
# SISTEMA OPERACIONAL E IDEs
# =====================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo

# =====================================================
# ENGENHARIA DE DADOS (Python/SQL/Parquet)
# =====================================================
# Ignora datasets pesados que devem estar no DVC ou Cloud Storage
*.csv
*.xlsx
*.parquet
*.sqlite
*.db
*.jsonl

# Python (Venv & Notebooks)
.venv/
env/
venv/
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
.python-version

# =====================================================
# TEMPORÁRIOS E BACKUPS
# =====================================================
*.tmp
*.temp
*.bak
*.old
*.patch
